# Copy to backend/.env and fill values. backend/.env is gitignored.

# Browser origins (comma-separated). Include production + local for cookies + SSE.
# CORS_ORIGIN=https://your-domain.com,http://localhost:5173,http://127.0.0.1:5173

# Supabase — server / scripts only (service role bypasses RLS; never expose in the browser)
# Use an http(s) REST URL for @supabase/supabase-js — NOT postgresql:// (use separate DATABASE_URL for psql if needed).

# --- Local (default for development: Docker + Supabase CLI)
# From backend/: npm run db:start  →  npm run db:push:local  (or npm run db:reset)
# Keys: npm run db:status — copy "service_role key" (JWT) into SUPABASE_SERVICE_ROLE_KEY
# If you paste `supabase status -o env`, rename API_URL → SUPABASE_URL and SERVICE_ROLE_KEY → SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=

# --- Cloud (staging/production) — comment local lines above when using remote
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — only if `supabase link` prompts for Postgres (cloud): Dashboard → Database password
# SUPABASE_DB_PASSWORD=

# When set, analyses + wallet users persist in Postgres (migrations under supabase/migrations/).
# Without these, analyses stay in-memory only (lost on restart).
# Anonymous dashboard workspace (no wallet): created on first API use with external_key:
# COCKPIT_DEFAULT_WORKSPACE_KEY=cockpit-default-workspace (default) and COCKPIT_ANON_WALLET=cockpit-anonymous (default)

# Jupiter Ultra — proxy at GET /ultra/v1/order?... (server injects x-api-key; never expose in Vite)
# JUPITER_ULTRA_API_KEY=
# Optional override if Jupiter changes host:
# JUPITER_ULTRA_ORDER_URL=https://api.jup.ag/ultra/v1/order

# Optional — S3-compatible Storage API (server-side access keys bypass RLS; never expose in Vite)
# https://supabase.com/docs/guides/storage/s3/authentication
# SUPABASE_STORAGE_S3_ENDPOINT=https://qdjwpjvezzxfrzlvufti.storage.supabase.co/storage/v1/s3
# SUPABASE_STORAGE_REGION=your-region-from-dashboard
# SUPABASE_STORAGE_ACCESS_KEY_ID=
# SUPABASE_STORAGE_SECRET_ACCESS_KEY=

# After applying migration 20260417120000_reference_datasets_icij_solana.sql, load CSV/JSON:
#   npm run db:import:reference-datasets -- --replace
# Smoke test: add --max-rows 100 (caps each ICIJ CSV + JSON array). ICIJ files are large; full import takes time.

# OpenAI — RAG ingest uses text-embedding-3-small (1536 dimensions)
OPENAI_API_KEY=

# OpenRouter — chat model for Deep Agents (supervisor + workers)
OPENROUTER_API_KEY=
# Optional
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Avoid placeholder values like `openai/free`; use a real OpenRouter model id.
# OPENROUTER_TEMPERATURE=0.2

# Optional — Chainalysis public Sanctions API (https://public.chainalysis.com — server-side only)
# CHAINALYSIS_API_KEY=

# Dune Sim API — realtime wallet / activity (https://docs.sim.dune.com — server-side only; header X-Sim-Api-Key)
# SIM_API_KEY=
# Optional override: SIM_API_BASE_URL=https://api.sim.dune.com

# Dune Analytics Data API — saved SQL executions (https://docs.dune.com/api-reference — separate from Sim)
# DUNE_API_KEY=

# Optional — Tavily web search / crawl / extract / research (server-side only)
# Docs index: https://docs.tavily.com/llms.txt
# TAVILY_API_KEY=

# Optional — ProjectDiscovery Katana CLI (local subprocess on this machine). https://github.com/projectdiscovery/katana
# go install github.com/projectdiscovery/katana/cmd/katana@latest
# KATANA_ENABLED=true
# KATANA_BIN=katana
# KATANA_MAX_OUTPUT_LINES=500

# Solana RPC — server-side only (never put API keys in the Vite bundle). See docs/rpc-helius-rpcfast-cockpit.md §1.4
# https://www.helius.dev/docs/rpc/protect-your-keys.md — optional Cloudflare proxy: https://github.com/helius-labs/helius-rpc-proxy
# HELIUS_API_KEY= (also used for Helius Wallet API when enabled)
# Optional explicit RPC URL if your stack builds it without storing the key in query string logs:
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Gatekeeper (optional edge RPC — same key): https://www.helius.dev/docs/gatekeeper/migration-guide.md
# SOLANA_RPC_URL=https://beta.helius-rpc.com/?api-key=YOUR_KEY
# Optional WSS for workers: wss://beta.helius-rpc.com/?api-key=YOUR_KEY (or mainnet host if not using Gatekeeper)
# RPC Fast (or other provider) — use their dashboard URL + auth pattern; keep credentials server-side only.
# RPCFAST_SOLANA_RPC_URL=

# Optional — Shodan Internet DB API (https://developer.shodan.io/api/openapi.json)
# SHODAN_API_KEY=

# Optional — GitHub API token (higher rate limits for torproject_github_repositories tool)
# GITHUB_TOKEN=

# Optional — Hudson Rock Community OSINT API (no key in public docs; ~50 requests / 10s)
# https://cavalier.hudsonrock.com/api/json/v2/osint-tools/ — set HUDSON_ROCK_ENABLED=false to disable tools
# HUDSON_ROCK_ENABLED=true
# HUDSON_ROCK_BASE_URL=https://cavalier.hudsonrock.com/api/json/v2/osint-tools

# Optional — SEAL Intel SDK (Security Alliance OpenCTI) — https://github.com/security-alliance/seal-intel-sdk
# GraphQL at <host>/graphql; use an API token and a STIX Identity id from your OpenCTI workspace for attribution.
# SEAL_INTEL_OPENCTI_HOST=https://sealisac.org
# SEAL_INTEL_API_KEY=
# SEAL_INTEL_IDENTITY_ID=identity--xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# SEAL_INTEL_ENABLED=true
# Block/trust/unblock tools (mutates indicators) — keep false unless operators explicitly enable writes:
# SEAL_INTEL_WRITE_ENABLED=false

# Optional — Firecrawl (https://firecrawl.dev — server-side only; consumes credits)
# FIRECRAWL_API_KEY=fc-your-api-key
# Optional: self-hosted or alternate API base
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# FIRECRAWL_ENABLED=true