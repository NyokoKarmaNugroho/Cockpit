# Public site URL (no trailing slash) — canonical + og:url; default in code is https://cockpitintel.com
# VITE_SITE_URL=https://cockpitintel.com

# Set to true so "Get started" buttons skip the modal and go straight to /build-dashboard.
# VITE_GET_STARTED_DIRECT_DASHBOARD=true

# Cockpit backend base URL for dashboard analysis APIs and SSE (no trailing slash).
# Local: http://localhost:8787 — Production: set to your API origin; backend must list this site in CORS_ORIGIN.
# Fetch and EventSource use credentials (cookies) for /auth and /dashboard/bootstrap.
# VITE_API_BASE_URL=http://localhost:8787

# Supabase (browser — use anon / publishable key; enforce access with RLS)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key

# Solana read RPC — Helius secure URL, helius-rpc-proxy worker, or other keyless/public endpoint (never put ?api-key= in the bundle).
# https://www.helius.dev/docs/rpc/protect-your-keys.md · https://github.com/helius-labs/helius-rpc-proxy
# See docs/rpc-helius-rpcfast-cockpit.md §1.4
# VITE_SOLANA_RPC_URL=
